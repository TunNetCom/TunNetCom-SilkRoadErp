@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> Localizer

<RadzenDialog />
<RadzenNotification />

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-p-2" Style="width: 100%; justify-content: space-between;">
            <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0">@Localizer["App_Title"]</RadzenText>
            <LanguageSelector />
        </RadzenStack>
    </RadzenHeader>
    <RadzenBody>
        <div class="rz-p-4" style="max-width: 800px; margin: 0 auto;">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>
