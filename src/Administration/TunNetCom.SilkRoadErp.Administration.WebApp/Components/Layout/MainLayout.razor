@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> Localizer

<RadzenDialog />
<RadzenNotification />

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-p-2" Style="width: 100%; justify-content: space-between;">
            <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0">@Localizer["App_Title"]</RadzenText>
            <LanguageSelector />
        </RadzenStack>
    </RadzenHeader>
    <RadzenBody>
        <RadzenRow>
            <RadzenColumn Size="2">
                <RadzenPanelMenu>
                    <RadzenPanelMenuItem Text="@Localizer["Dashboard"]" Icon="dashboard" Path="/" />
                    <RadzenPanelMenuItem Text="@Localizer["Tenants"]" Icon="business" Path="/tenants" />
                    <RadzenPanelMenuItem Text="@Localizer["Plans"]" Icon="payments" Path="/plans" />
                    <RadzenPanelMenuItem Text="@Localizer["Bounded_Contexts"]" Icon="extension" Path="/bounded-contexts" />
                </RadzenPanelMenu>
            </RadzenColumn>
            <RadzenColumn Size="10">
                <div class="rz-p-4">
                    @Body
                </div>
            </RadzenColumn>
        </RadzenRow>
    </RadzenBody>
</RadzenLayout>
