@inherits LayoutComponentBase

<RadzenDialog />
<RadzenNotification />

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-p-2">
            <RadzenText TextStyle="TextStyle.H5" class="rz-mb-0">SilkRoad ERP - Administration</RadzenText>
        </RadzenStack>
    </RadzenHeader>
    <RadzenBody>
        <RadzenRow>
            <RadzenColumn Size="2">
                <RadzenPanelMenu>
                    <RadzenPanelMenuItem Text="Dashboard" Icon="dashboard" Path="/" />
                    <RadzenPanelMenuItem Text="Tenants" Icon="business" Path="/tenants" />
                    <RadzenPanelMenuItem Text="Plans" Icon="payments" Path="/plans" />
                    <RadzenPanelMenuItem Text="Bounded Contexts" Icon="extension" Path="/bounded-contexts" />
                </RadzenPanelMenu>
            </RadzenColumn>
            <RadzenColumn Size="10">
                <div class="rz-p-4">
                    @Body
                </div>
            </RadzenColumn>
        </RadzenRow>
    </RadzenBody>
</RadzenLayout>
